# Copy this file to .env and fill in your Firebase project values.
# Find them in: Firebase Console → Project settings → Your apps → SDK setup.
# For the live static site, mirror the same values into env.js.
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
